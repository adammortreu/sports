function TodayTab({ tasks, toggleTask, todayLog }) {
  const prog = PROGRAM[TODAY_IDX];
  const inf = INFUSIONS[TODAY_IDX];
  const meal = MEALS_WEEK[TODAY_IDX];
  const done = tasks.filter(Boolean).length;
  const pct = Math.round((done / ROUTINE_TASKS.length) * 100);

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
      {/* Header du jour */}
      <Card style={{ background: `linear-gradient(135deg, ${C.card} 0%, #1A2035 100%)`, borderColor: prog.color + "44" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
          <div>
            <p style={{ margin: 0, color: C.textMuted, fontSize: 13, textTransform: "uppercase", letterSpacing: 1 }}>
              {DAYS[TODAY_IDX]} · {new Date().toLocaleDateString("fr-FR", { day: "numeric", month: "long" })}
            </p>
            <h1 style={{ margin: "6px 0 4px", fontSize: 26, fontWeight: 800, color: C.text }}>
              {prog.icon} {prog.label}
            </h1>
            <Badge color={prog.color}>{prog.type === "salle" ? "Salle" : prog.type === "running" ? "Running" : "Repos actif"}</Badge>
          </div>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 36, fontWeight: 800, color: pct === 100 ? C.green : C.text }}>{pct}%</div>
            <div style={{ fontSize: 12, color: C.textMuted }}>Routine</div>
          </div>
        </div>
        {/* Progress bar */}
        <div style={{ marginTop: 16, background: C.border, borderRadius: 99, height: 6 }}>
          <div style={{ width: `${pct}%`, height: 6, borderRadius: 99, background: `linear-gradient(90deg, ${C.greenDim}, ${C.green})`, transition: "width 0.4s ease" }} />
        </div>
      </Card>

      {/* Routine du jour */}
      <Card>
        <SectionTitle icon="✅" title="Routine du jour" sub="Coche au fur et à mesure" />
        <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
          {ROUTINE_TASKS.map((t, i) => (
            <button key={t.id} onClick={() => toggleTask(i)}
              style={{ display: "flex", alignItems: "center", gap: 14, padding: "12px 16px", borderRadius: 10,
                background: tasks[i] ? C.greenGlow : C.surface, border: `1px solid ${tasks[i] ? C.green + "55" : C.border}`,
