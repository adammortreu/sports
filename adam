function ProgressTab({ logs }) {
  const start = new Date("2025-07-01");
  const today = new Date();
  const daysSinceStart = Math.max(0, Math.floor((today - start) / 86400000));
  const weeksSinceStart = Math.floor(daysSinceStart / 7) + 1;

  const currentWeekProg = RUNNING_WEEKS[Math.min(weeksSinceStart - 1, RUNNING_WEEKS.length - 1)];

  const poidsLogs = logs.filter(l => l.poids).reverse();
  const runLogs = logs.filter(l => l.running).reverse();
  const startPoids = 76;
  const latestPoids = poidsLogs.length > 0 ? parseFloat(poidsLogs[poidsLogs.length - 1].poids) : null;
  const latestRun = runLogs.length > 0 ? parseFloat(runLogs[runLogs.length - 1].running) : 3;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
      {/* Objectifs */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12 }}>
        {[
          { label: "Fin juillet", date: "31 jul", run: "5 km", masse: "+1-2 kg", color: C.orange },
          { label: "Fin août", date: "31 août", run: "7 km", masse: "+3-4 kg", color: C.green },
