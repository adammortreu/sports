  const [checked, setChecked] = useState({});
  const [activeSection, setActiveSection] = useState("proteines");

  const sections = [
    { id: "proteines", label: "Protéines", icon: "🥩" },
    { id: "feculents", label: "Féculents", icon: "🌾" },
    { id: "legumes", label: "Légumes", icon: "🥬" },
    { id: "fruits", label: "Fruits", icon: "🍌" },
    { id: "complements", label: "Compléments", icon: "🫒" },
    { id: "infusions", label: "Shots & Infusions", icon: "🫖" },
    { id: "epices", label: "Épices", icon: "🟤" },
  ];

  const toggleItem = (key) => setChecked(prev => ({ ...prev, [key]: !prev[key] }));
  const totalItems = Object.values(SHOPPING_LIST).flat().length;
  const checkedCount = Object.values(checked).filter(Boolean).length;

  const currentList = SHOPPING_LIST[activeSection] || [];
  const sectionChecked = currentList.filter((_, i) => checked[`${activeSection}_${i}`]).length;

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
      {/* Header progress */}
      <Card style={{ borderColor: C.green + "44" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 10 }}>
          <div>
            <div style={{ fontSize: 18, fontWeight: 800, color: C.text }}>🛒 Liste de courses</div>
            <div style={{ color: C.textMuted, fontSize: 13, marginTop: 2 }}>Pour la semaine · Halal · Anti-fermentation</div>
          </div>
          <div style={{ textAlign: "center" }}>
            <div style={{ fontSize: 26, fontWeight: 800, color: checkedCount === totalItems ? C.green : C.text }}>{checkedCount}/{totalItems}</div>
            <div style={{ fontSize: 11, color: C.textMuted }}>cochés</div>
          </div>
        </div>
        <div style={{ background: C.border, borderRadius: 99, height: 6 }}>
          <div style={{ width: `${(checkedCount/totalItems)*100}%`, height: 6, borderRadius: 99, background: `linear-gradient(90deg, ${C.greenDim}, ${C.green})`, transition: "width 0.3s" }} />
        </div>
      </Card>

      {/* Section tabs */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 6 }}>
        {sections.map(s => {
          const list = SHOPPING_LIST[s.id] || [];
          const done = list.filter((_, i) => checked[`${s.id}_${i}`]).length;
          const isActive = activeSection === s.id;
          return (
            <button key={s.id} onClick={() => setActiveSection(s.id)}
              style={{ padding: "8px 4px", borderRadius: 8, border: `1px solid ${isActive ? C.green : C.border}`,
                background: isActive ? C.greenGlow : C.surface, cursor: "pointer", textAlign: "center" }}>
              <div style={{ fontSize: 16 }}>{s.icon}</div>
              <div style={{ fontSize: 10, color: isActive ? C.green : C.textMuted, fontWeight: 600, marginTop: 2 }}>{s.label}</div>
              {done > 0 && <div style={{ fontSize: 10, color: C.green }}>{done}/{list.length}</div>}
            </button>
          );
        })}
      </div>

      {/* Liste */}
      <Card>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14 }}>
          <div style={{ fontWeight: 700, fontSize: 16, color: C.text }}>
            {sections.find(s => s.id === activeSection)?.icon} {sections.find(s => s.id === activeSection)?.label}
          </div>
          <div style={{ color: C.textMuted, fontSize: 12 }}>{sectionChecked}/{currentList.length} cochés</div>
        </div>
        <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
          {currentList.map((item, i) => {
            const key = `${activeSection}_${i}`;
            const isDone = checked[key];
            return (
              <button key={i} onClick={() => toggleItem(key)}
                style={{ display: "flex", alignItems: "center", gap: 12, padding: "12px 14px", borderRadius: 10,
                  background: isDone ? C.greenGlow : C.surface, border: `1px solid ${isDone ? C.green + "44" : C.border}`,
                  cursor: "pointer", textAlign: "left", transition: "all 0.2s" }}>
                <div style={{ width: 20, height: 20, borderRadius: 6, border: `2px solid ${isDone ? C.green : C.border}`,
                  background: isDone ? C.green : "transparent", display: "flex", alignItems: "center", justifyContent: "center", flexShrink: 0 }}>
                  {isDone && <span style={{ color: "#000", fontSize: 12, fontWeight: 800 }}>✓</span>}
                </div>
                <span style={{ fontSize: 18, flexShrink: 0 }}>{item.cat}</span>
                <span style={{ flex: 1, color: isDone ? C.textMuted : C.text, fontSize: 14,
                  textDecoration: isDone ? "line-through" : "none", opacity: isDone ? 0.6 : 1 }}>
                  {item.item}
                </span>
                <span style={{ color: C.textMuted, fontSize: 12, flexShrink: 0 }}>{item.qty}</span>
              </button>
            );
          })}
        </div>
      </Card>

      {/* Tips batch cooking */}
      <Card style={{ borderColor: C.orange + "44" }}>
        <div style={{ fontWeight: 700, color: C.orange, marginBottom: 8 }}>💡 Batch cooking — Dimanche + Mercredi</div>
        <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
          {["Riz basmati : prépare 400g · se conserve 4 jours au frigo",
            "Poulet : grille 4-5 blancs · épices · 3-4 jours au frigo",
            "Légumes vapeur : carottes + courgettes + haricots · 3 jours",
            "Patate douce rôtie : 3-4 pièces au four 200°C · 4 jours",
          ].map((tip, i) => (
            <div key={i} style={{ display: "flex", gap: 8, color: C.text, fontSize: 13 }}>
              <span style={{ color: C.orange, flexShrink: 0 }}>→</span>
              <span>{tip}</span>
            </div>
          ))}
        </div>
      </Card>
    </div>
  );
}

// ─── MAIN APP ───
export default function App() {
  const [activeTab, setActiveTab] = useState("today");
  const [tasks, setTasks] = useState(Array(ROUTINE_TASKS.length).fill(false));
  const [logs, setLogs] = useState([]);
  const [loaded, setLoaded] = useState(false);

  const todayKey = `tasks_${new Date().toISOString().split("T")[0]}`;

  useEffect(() => {
    (async () => {
      const savedTasks = await getStorage(todayKey);
      if (savedTasks) setTasks(savedTasks);
      const savedLogs = await getStorage("logs");
      if (savedLogs) setLogs(savedLogs);
      setLoaded(true);
    })();
  }, []);

  const toggleTask = async (i) => {
    const next = tasks.map((v, idx) => idx === i ? !v : v);
    setTasks(next);
    await setStorage(todayKey, next);
  };

  const addLog = async (newLogs) => {
    setLogs(newLogs);
    await setStorage("logs", newLogs);
  };

  if (!loaded) return (
    <div style={{ background: C.bg, minHeight: "100vh", display: "flex", alignItems: "center", justifyContent: "center" }}>
      <div style={{ color: C.green, fontSize: 18 }}>Chargement...</div>
    </div>
  );

  return (
    <div style={{ background: C.bg, minHeight: "100vh", fontFamily: "'Inter', -apple-system, sans-serif", color: C.text }}>
      {/* Header */}
      <div style={{ background: C.surface, borderBottom: `1px solid ${C.border}`, padding: "16px 20px", position: "sticky", top: 0, zIndex: 100 }}>
        <div style={{ maxWidth: 800, margin: "0 auto", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <div>
            <div style={{ fontSize: 11, color: C.green, fontWeight: 700, textTransform: "uppercase", letterSpacing: 1.5 }}>the_rebornlife</div>
            <div style={{ fontSize: 18, fontWeight: 800, color: C.text, marginTop: 2 }}>Programme Été 2025</div>
          </div>
          <div style={{ textAlign: "right" }}>
            <div style={{ fontSize: 12, color: C.textMuted }}>{new Date().toLocaleDateString("fr-FR", { weekday: "long", day: "numeric", month: "long" })}</div>
            <div style={{ fontSize: 12, color: C.green, fontWeight: 600, marginTop: 2 }}>
              {tasks.filter(Boolean).length}/{ROUTINE_TASKS.length} tâches ✓
            </div>
          </div>
        </div>
      </div>

      {/* Tabs */}
      <div style={{ background: C.surface, borderBottom: `1px solid ${C.border}`, overflowX: "auto" }}>
        <div style={{ maxWidth: 800, margin: "0 auto", display: "flex", padding: "0 12px" }}>
          {TABS.map(tab => (
            <button key={tab.id} onClick={() => setActiveTab(tab.id)}
              style={{ padding: "12px 14px", border: "none", background: "transparent", cursor: "pointer", whiteSpace: "nowrap",
                color: activeTab === tab.id ? C.green : C.textMuted, fontWeight: activeTab === tab.id ? 700 : 400,
                fontSize: 13, borderBottom: `2px solid ${activeTab === tab.id ? C.green : "transparent"}`, transition: "all 0.2s" }}>
              {tab.icon} {tab.label}
            </button>
          ))}
        </div>
      </div>

      {/* Content */}
      <div style={{ maxWidth: 800, margin: "0 auto", padding: "20px 16px 80px" }}>
        {activeTab === "today" && <TodayTab tasks={tasks} toggleTask={toggleTask} />}
        {activeTab === "tracker" && <TrackerTab logs={logs} addLog={addLog} />}
        {activeTab === "programme" && <ProgrammeTab />}
        {activeTab === "nutrition" && <NutritionTab />}
        {activeTab === "shots" && <ShotsTab />}
        {activeTab === "courses" && <CoursesTab />}
        {activeTab === "progress" && <ProgressTab logs={logs} />}
      </div>
    </div>
  );
}
