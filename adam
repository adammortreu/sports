// ─── TRACKER TAB ───
function TrackerTab({ logs, addLog }) {
  const [form, setForm] = useState({ date: new Date().toISOString().split("T")[0], poids: "", running: "", notes: "" });
  const [saved, setSaved] = useState(false);

  const handleSave = async () => {
    const newLogs = [form, ...logs].slice(0, 60);
    await addLog(newLogs);
    setSaved(true);
    setTimeout(() => setSaved(false), 2000);
  };

  const poidsData = logs.filter(l => l.poids).slice(0, 10).reverse();
  const runData = logs.filter(l => l.running).slice(0, 10).reverse();

  return (
    <div style={{ display: "flex", flexDirection: "column", gap: 20 }}>
      {/* Saisie */}
      <Card>
        <SectionTitle icon="📝" title="Saisie du jour" sub="Enregistre ta progression" />
        <div style={{ display: "flex", flexDirection: "column", gap: 12 }}>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 10 }}>
            {[["Date", "date", "date"], ["Poids (kg)", "poids", "number"], ["Running (km)", "running", "number"]].map(([label, key, type]) => (
              <div key={key}>
                <label style={{ color: C.textMuted, fontSize: 12, fontWeight: 600, display: "block", marginBottom: 4 }}>{label}</label>
                <input type={type} value={form[key]} onChange={e => setForm({ ...form, [key]: e.target.value })}
                  style={{ width: "100%", background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8, padding: "10px 12px",
                    color: C.text, fontSize: 14, outline: "none", boxSizing: "border-box" }} />
              </div>
            ))}
          </div>
          <div>
            <label style={{ color: C.textMuted, fontSize: 12, fontWeight: 600, display: "block", marginBottom: 4 }}>Notes / Ressenti</label>
            <textarea value={form.notes} onChange={e => setForm({ ...form, notes: e.target.value })} rows={2}
              style={{ width: "100%", background: C.surface, border: `1px solid ${C.border}`, borderRadius: 8, padding: "10px 12px",
                color: C.text, fontSize: 14, outline: "none", resize: "none", boxSizing: "border-box" }} />
          </div>
          <button onClick={handleSave}
            style={{ background: saved ? C.greenDim : C.green, color: "#000", fontWeight: 700, fontSize: 15, padding: "12px 0",
              borderRadius: 10, border: "none", cursor: "pointer", transition: "all 0.2s" }}>
            {saved ? "✓ Enregistré" : "Sauvegarder"}
          </button>
        </div>
      </Card>

      {/* Stats rapides */}
      {logs.length > 0 && (
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 12 }}>
          {[
            { label: "Poids actuel", val: logs.find(l => l.poids)?.poids ? `${logs.find(l => l.poids).poids} kg` : "—", color: C.blue },
            { label: "Dernier run", val: logs.find(l => l.running)?.running ? `${logs.find(l => l.running).running} km` : "—", color: C.orange },
            { label: "Sessions", val: logs.length, color: C.green },
          ].map(({ label, val, color }) => (
            <Card key={label} style={{ textAlign: "center", padding: "16px 12px" }}>
              <div style={{ fontSize: 26, fontWeight: 800, color }}>{val}</div>
              <div style={{ color: C.textMuted, fontSize: 12, marginTop: 4 }}>{label}</div>
            </Card>
          ))}
        </div>
      )}

      {/* Historique */}
      {logs.length > 0 && (
        <Card>
          <SectionTitle icon="📋" title="Historique" sub={`${logs.length} entrée${logs.length > 1 ? "s" : ""}`} />
          <div style={{ display: "flex", flexDirection: "column", gap: 8, maxHeight: 320, overflowY: "auto" }}>
            {logs.map((l, i) => (
