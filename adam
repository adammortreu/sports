            </div>
          </Card>
        ))}
      </div>

      {/* Semaine en cours */}
      <Card style={{ borderColor: C.green + "44" }}>
        <SectionTitle icon="📍" title={`Semaine ${weeksSinceStart} — En cours`} />
        <div style={{ background: C.greenGlow, borderRadius: 10, padding: "14px 16px", border: `1px solid ${C.green}33` }}>
          <div style={{ fontSize: 20, fontWeight: 800, color: C.green }}>{currentWeekProg?.dist || "3 → 3,5 km"}</div>
          <div style={{ color: C.textSub, fontSize: 13, marginTop: 4 }}>{currentWeekProg?.cap || "Poser la routine"}</div>
        </div>
      </Card>

      {/* Progression running */}
      <Card>
        <SectionTitle icon="🏃" title="Progression Running" sub="Départ : 3 km · Semi-marathon visé automne" />
        <div style={{ display: "flex", flexDirection: "column", gap: 6 }}>
          {RUNNING_WEEKS.map((w, i) => {
            const isCurrent = i === Math.min(weeksSinceStart - 1, RUNNING_WEEKS.length - 1);
            const isPast = i < weeksSinceStart - 1;
            return (
              <div key={i} style={{ display: "flex", alignItems: "center", gap: 12, padding: "10px 12px", borderRadius: 10,
                background: isCurrent ? C.greenGlow : isPast ? "transparent" : "transparent",
