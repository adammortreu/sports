                {tasks[i] && <span style={{ color: "#000", fontSize: 13, fontWeight: 800 }}>✓</span>}
              </div>
              <span style={{ fontSize: 16 }}>{t.icon}</span>
              <span style={{ color: tasks[i] ? C.green : C.text, fontSize: 14, fontWeight: tasks[i] ? 600 : 400, textDecoration: tasks[i] ? "line-through" : "none", opacity: tasks[i] ? 0.7 : 1 }}>
